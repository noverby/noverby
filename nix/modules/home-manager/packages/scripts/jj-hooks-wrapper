#!/usr/bin/env nu

def --wrapped main [...args: string] {
    let real_jj = "@JJ_BIN@"

    if ($args | is-empty) {
        ^$real_jj
        return
    }

    let subcommand = $args.0

    # Run pre-commit hook for commands that finalize changes.
    # First trigger a jj snapshot so the git HEAD reflects the working copy,
    # then sync the git index with `git add -A`. Without this, prek/pre-commit
    # sees index-vs-worktree differences as "unstaged changes", stashes them,
    # and fails to restore the stash when renamed/moved files already exist.
    if $subcommand in ["commit" "new" "squash"] {
        ^$real_jj status out+err> /dev/null
        ^git add -A out+err> /dev/null
        run-git-hook "pre-commit"
    }

    # Run prepare-commit-msg hook when -m/--message is provided
    if $subcommand in ["commit" "describe" "new"] {
        let msg = (extract-message $args)
        if $msg != null {
            validate-commit-message $msg
        }
    }

    # Capture the current commit description before running jj, so we can
    # detect editor-based changes that bypass the -m flag.
    let needs_post_validate = (
        $subcommand in ["commit" "describe"]
        and (extract-message $args) == null
        and not ($args | any {|a| $a == "--no-edit" or $a == "--stdin" })
    )
    let pre_description = if $needs_post_validate {
        get-current-description $real_jj $subcommand $args
    } else {
        null
    }

    # Run the real jj
    ^$real_jj ...$args
    let jj_exit = $env.LAST_EXIT_CODE? | default 0

    if $jj_exit != 0 {
        exit $jj_exit
    }

    # Post-hoc validation: if an editor-based command changed the description,
    # validate the new message. On failure, restore the old description.
    if $needs_post_validate {
        let post_description = get-working-description $real_jj $subcommand
        if $post_description != null and $post_description != "" and $post_description != $pre_description {
            let valid = (do { validate-commit-message $post_description } | complete)
            if $valid.exit_code != 0 {
                # Restore the previous description to reject the invalid message
                if $subcommand == "describe" {
                    if $pre_description != null and $pre_description != "" {
                        ^$real_jj describe -m $pre_description out+err> /dev/null
                    } else {
                        ^$real_jj describe -m "" out+err> /dev/null
                    }
                    print $"(ansi red)Error: Commit message failed validation. Description has been reverted.(ansi reset)"
                } else if $subcommand == "commit" {
                    # For commit, undo the operation to revert the commit
                    ^$real_jj undo out+err> /dev/null
                    print $"(ansi red)Error: Commit message failed validation. Commit has been undone.(ansi reset)"
                }
                exit 1
            }
        }
    }
}

# Get the description of the current working copy change before running jj
def get-current-description [real_jj: string, subcommand: string, args: list<string>] {
    # For both `describe` and `commit`, the message being edited is the
    # current working-copy change's description (or the revision targeted
    # by -r for describe).
    let rev = if $subcommand == "describe" {
        extract-revision $args | default "@"
    } else {
        "@"
    }
    try {
        ^$real_jj log -r $rev --no-graph -T 'description' --ignore-working-copy | str trim
    } catch {
        ""
    }
}

# Get the description of the relevant commit after jj ran
def get-working-description [real_jj: string, subcommand: string] {
    let rev = if $subcommand == "commit" {
        # After `jj commit`, the committed change is now @-
        "@-"
    } else {
        "@"
    }
    try {
        ^$real_jj log -r $rev --no-graph -T 'description' --ignore-working-copy | str trim
    } catch {
        null
    }
}

# Extract the -r/--revision argument for describe
def extract-revision [args: list<string>] {
    mut i = 1
    let len = ($args | length)
    while $i < $len {
        let arg = ($args | get $i)
        if $arg == "-r" or $arg == "--revision" {
            if ($i + 1) < $len {
                return ($args | get ($i + 1))
            }
        } else if ($arg | str starts-with "--revision=") {
            return ($arg | str substring 11..)
        } else if ($arg | str starts-with "-r") and ($arg | str length) > 2 {
            return ($arg | str substring 2..)
        }
        $i += 1
    }
    null
}

def run-git-hook [hook: string] {
    let hook_path = $".git/hooks/($hook)"
    if ($hook_path | path exists) {
        try {
            ^$hook_path
        } catch {
            exit 1
        }
    }
}

def extract-message [args: list<string>] {
    mut i = 1
    let len = ($args | length)
    while $i < $len {
        let arg = ($args | get $i)
        if $arg == "-m" or $arg == "--message" {
            if ($i + 1) < $len {
                return ($args | get ($i + 1))
            }
        } else if ($arg | str starts-with "--message=") {
            return ($arg | str substring 10..)
        } else if ($arg | str starts-with "-m") and ($arg | str length) > 2 {
            return ($arg | str substring 2..)
        }
        $i += 1
    }
    null
}

def validate-commit-message [msg: string] {
    let hook_path = ".git/hooks/prepare-commit-msg"
    if not ($hook_path | path exists) {
        return
    }
    let tmpfile = (mktemp -t "jj-commit-msg-XXXXXX")
    $msg | save -f $tmpfile
    try {
        ^$hook_path $tmpfile "message"
    } catch {
        rm -f $tmpfile
        exit 1
    }
    rm -f $tmpfile
}