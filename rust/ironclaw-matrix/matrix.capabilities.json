{
	"version": "0.1.0",
	"wit_version": "0.3.0",
	"type": "channel",
	"name": "matrix",
	"description": "Matrix channel for receiving and responding to Matrix messages via the Client-Server API",
	"auth": {
		"secret_name": "matrix_access_token",
		"display_name": "Matrix",
		"instructions": "Create a Matrix bot account and generate an access token. You can use Element or any Matrix client to register, then get a token via the login API or client settings.",
		"token_hint": "Looks like syt_...",
		"env_var": "MATRIX_ACCESS_TOKEN"
	},
	"setup": {
		"required_secrets": [
			{
				"name": "matrix_access_token",
				"prompt": "Enter your Matrix bot access token",
				"optional": false
			}
		],
		"validation_endpoint": "{homeserver}/_matrix/client/v3/account/whoami"
	},
	"capabilities": {
		"http": {
			"allowlist": [{ "host": "*", "path_prefix": "/_matrix/" }],
			"credentials": {
				"matrix_token": {
					"secret_name": "matrix_access_token",
					"location": {
						"type": "header",
						"name": "Authorization",
						"prefix": "Bearer "
					},
					"host_patterns": ["*"]
				}
			},
			"max_response_bytes": 52428800,
			"rate_limit": {
				"requests_per_minute": 60,
				"requests_per_hour": 3000
			}
		},
		"secrets": {
			"allowed_names": ["matrix_*"]
		},
		"channel": {
			"allowed_paths": ["/webhook/matrix"],
			"allow_polling": true,
			"min_poll_interval_ms": 30000,
			"workspace_prefix": "channels/matrix/",
			"emit_rate_limit": {
				"messages_per_minute": 100,
				"messages_per_hour": 5000
			}
		}
	},
	"config": {
		"homeserver": "https://matrix.org",
		"dm_policy": "pairing",
		"allow_from": [],
		"room_ids": [],
		"require_mention": false
	}
}
