# Show component status (available, planned, etc.)
status:
    nix build .#rust-nixpkgs-test --no-link --print-build-logs

# Build the test derivation (verifies all components are available)
test:
    nix build .#rust-nixpkgs-test

# Build with the Rust stdenv (verifies stdenv override works end-to-end)
test-stdenv:
    nix build .#rust-nixpkgs-stdenv-test --no-link --print-build-logs

# Explore the stdenvRs closure
tree:
    nix-tree .#rust-nixpkgs-test

# Run all package build tests
test-all:
    #!/usr/bin/env bash
    set -e
    tests=(rust-nixpkgs-test rust-nixpkgs-stdenv-test rust-nixpkgs-hello-test rust-nixpkgs-zlib-test rust-nixpkgs-gnupatch-test rust-nixpkgs-coreutils-test rust-nixpkgs-gnugrep-test rust-nixpkgs-gnused-test rust-nixpkgs-gnudiffutils-test rust-nixpkgs-gnumake-test)
    for test in "${tests[@]}"; do
        echo -n "$test: "
        if nix build ".#$test" --no-link 2>/dev/null; then
            echo "PASS"
        else
            echo "FAIL"
        fi
    done

# List all component files
components:
    @echo "=== Component Registry ==="
    @for f in components/*.nix; do \
        [ "$(basename "$f")" = "default.nix" ] && continue; \
        name="$(basename "$f" .nix)"; \
        if grep -q 'status.available' "$f"; then \
            echo "  ✅ $name"; \
        elif grep -q 'status.inProgress' "$f"; then \
            echo "  🔧 $name"; \
        else \
            echo "  ⏳ $name"; \
        fi; \
    done
