#!/usr/bin/env -S nu --stdin 
def main [] {
    let input = $in
    if ($input | is-empty) {
        print "Please provide input through a pipe"
        exit 1
    }
    
    let lines = ($input | lines)

    let paths = ($lines 
        | each { |line|
            $line 
            | split row -r '\s+'
            | filter { |match| 
                ($match | path exists) and (($match | path type) in ['file', 'dir']) or ($match | parse --regex '^(https?|ftp):\/\/[^\s/$.?#].[^\s]*$' | is-not-empty)
            }
        }
        | get 0
    )
    $paths | uniq
}

