# Show component status (available, planned, etc.)
status:
    nix build .#nixpkgs-rs-test --no-link --print-build-logs

# Build the test derivation
test:
    nix build .#nixpkgs-rs-test

# Explore the stdenvRs closure
tree:
    nix-tree .#nixpkgs-rs-test

# Build a simple hello-world package using the Rust stdenv overlay
test-hello:
    nix build --impure --expr 'let pkgs = import <nixpkgs> { overlays = [ (import ./default.nix).overlays.nixpkgs-rs ]; }; in pkgs.mkDerivationRs { pname = "hello-rs"; version = "0.1.0"; dontUnpack = true; buildPhase = "echo hello from Rust stdenv"; installPhase = "mkdir -p $out && echo ok > $out/result"; }'

# List all component files
components:
    @echo "=== Component Registry ==="
    @for f in components/*.nix; do \
        [ "$(basename "$f")" = "default.nix" ] && continue; \
        name="$(basename "$f" .nix)"; \
        if grep -q 'status.available' "$f"; then \
            echo "  ✅ $name"; \
        elif grep -q 'status.inProgress' "$f"; then \
            echo "  🔧 $name"; \
        else \
            echo "  ⏳ $name"; \
        fi; \
    done
