#!/usr/bin/env nu

def --wrapped main [...args: string] {
    let real_jj = "@JJ_BIN@"

    if ($args | is-empty) {
        ^$real_jj
        return
    }

    let subcommand = $args.0

    # Run pre-commit hook for commands that finalize changes
    if $subcommand in ["commit" "new" "squash"] {
        run-git-hook "pre-commit"
    }

    # Run prepare-commit-msg hook when -m/--message is provided
    if $subcommand in ["commit" "describe" "new"] {
        let msg = (extract-message $args)
        if $msg != null {
            validate-commit-message $msg
        }
    }

    # Run the real jj
    ^$real_jj ...$args
}

def run-git-hook [hook: string] {
    let hook_path = $".git/hooks/($hook)"
    if ($hook_path | path exists) {
        try {
            ^$hook_path
        } catch {
            exit 1
        }
    }
}

def extract-message [args: list<string>] {
    mut i = 1
    let len = ($args | length)
    while $i < $len {
        let arg = ($args | get $i)
        if $arg == "-m" or $arg == "--message" {
            if ($i + 1) < $len {
                return ($args | get ($i + 1))
            }
        } else if ($arg | str starts-with "--message=") {
            return ($arg | str substring 10..)
        } else if ($arg | str starts-with "-m") and ($arg | str length) > 2 {
            return ($arg | str substring 2..)
        }
        $i += 1
    }
    null
}

def validate-commit-message [msg: string] {
    let hook_path = ".git/hooks/prepare-commit-msg"
    if not ($hook_path | path exists) {
        return
    }
    let tmpfile = (mktemp -t "jj-commit-msg-XXXXXX")
    $msg | save -f $tmpfile
    try {
        ^$hook_path $tmpfile "message"
    } catch {
        rm -f $tmpfile
        exit 1
    }
    rm -f $tmpfile
}
