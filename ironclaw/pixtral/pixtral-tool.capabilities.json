{
	"version": "0.1.0",
	"wit_version": "0.3.0",
	"type": "tool",
	"name": "pixtral",
	"description": "Generate images using the Mistral AI image generation API",
	"capabilities": {
		"http": {
			"allowlist": [
				{
					"host": "api.mistral.ai",
					"path_prefix": "/v1/",
					"methods": ["POST", "GET"]
				}
			],
			"credentials": {
				"mistral_token": {
					"secret_name": "mistral_api_key",
					"location": {
						"type": "header",
						"name": "Authorization",
						"prefix": "Bearer "
					},
					"host_patterns": ["api.mistral.ai"]
				}
			},
			"rate_limit": {
				"requests_per_minute": 10,
				"requests_per_hour": 100
			}
		}
	}
}
