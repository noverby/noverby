{
	"version": "0.1.0",
	"wit_version": "0.3.0",
	"type": "tool",
	"name": "pixtral",
	"description": "Generate images using the Mistral AI image generation API",
	"auth": {
		"secret_name": "mistral_api_key",
		"display_name": "Mistral AI",
		"instructions": "Get your API key from https://console.mistral.ai/api-keys",
		"token_hint": "Looks like a long alphanumeric string",
		"env_var": "MISTRAL_API_KEY"
	},
	"setup": {
		"required_secrets": [
			{
				"name": "mistral_api_key",
				"prompt": "Enter your Mistral AI API key",
				"optional": false
			}
		]
	},
	"capabilities": {
		"http": {
			"allowlist": [
				{
					"host": "api.mistral.ai",
					"path_prefix": "/v1/",
					"methods": ["POST", "GET"]
				}
			],
			"credentials": {
				"mistral_token": {
					"secret_name": "mistral_api_key",
					"location": {
						"type": "header",
						"name": "Authorization",
						"prefix": "Bearer "
					},
					"host_patterns": ["api.mistral.ai"]
				}
			},
			"rate_limit": {
				"requests_per_minute": 10,
				"requests_per_hour": 100
			}
		}
	}
}
