{
	"version": "0.1.0",
	"wit_version": "0.3.0",
	"type": "channel",
	"name": "contacts",
	"description": "Contacts channel for managing address book entries via CardDAV",
	"auth": {
		"secret_name": "contacts_auth_token",
		"display_name": "Contacts (CardDAV)",
		"instructions": "Provide CardDAV server credentials. For Stalwart, use the same credentials as your email account. The token should be base64-encoded username:password.",
		"token_hint": "Base64-encoded username:password for CardDAV Basic auth",
		"env_var": "CONTACTS_AUTH_TOKEN"
	},
	"setup": {
		"required_secrets": [
			{
				"name": "contacts_auth_token",
				"prompt": "Enter the CardDAV authentication token (base64 of username:password)",
				"optional": false
			}
		]
	},
	"capabilities": {
		"http": {
			"allowlist": [{ "host": "*", "path_prefix": "/" }],
			"credentials": {
				"contacts_token": {
					"secret_name": "contacts_auth_token",
					"location": {
						"type": "header",
						"name": "Authorization",
						"prefix": "Basic "
					},
					"host_patterns": ["*"]
				}
			},
			"max_response_bytes": 10485760,
			"rate_limit": {
				"requests_per_minute": 60,
				"requests_per_hour": 3000
			}
		},
		"secrets": {
			"allowed_names": ["contacts_*"]
		},
		"channel": {
			"allowed_paths": ["/webhook/contacts"],
			"allow_polling": true,
			"min_poll_interval_ms": 60000,
			"workspace_prefix": "channels/contacts/",
			"emit_rate_limit": {
				"messages_per_minute": 30,
				"messages_per_hour": 500
			}
		}
	},
	"config": {
		"carddav_url": "http://localhost:8080",
		"addressbook_name": "default"
	}
}
