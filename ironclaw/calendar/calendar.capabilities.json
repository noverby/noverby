{
	"version": "0.1.0",
	"wit_version": "0.3.0",
	"type": "channel",
	"name": "calendar",
	"description": "Calendar channel for managing events and schedules via CalDAV",
	"auth": {
		"secret_name": "calendar_auth_token",
		"display_name": "Calendar (CalDAV)",
		"instructions": "Provide CalDAV server credentials. For Stalwart, use the same credentials as your email account. The token should be base64-encoded username:password.",
		"token_hint": "Base64-encoded username:password for CalDAV Basic auth",
		"env_var": "CALENDAR_AUTH_TOKEN"
	},
	"setup": {
		"required_secrets": [
			{
				"name": "calendar_auth_token",
				"prompt": "Enter the CalDAV authentication token (base64 of username:password)",
				"optional": false
			}
		]
	},
	"capabilities": {
		"http": {
			"allowlist": [{ "host": "*", "path_prefix": "/" }],
			"credentials": {
				"calendar_token": {
					"secret_name": "calendar_auth_token",
					"location": {
						"type": "header",
						"name": "Authorization",
						"prefix": "Basic "
					},
					"host_patterns": ["*"]
				}
			},
			"max_response_bytes": 10485760,
			"rate_limit": {
				"requests_per_minute": 60,
				"requests_per_hour": 3000
			}
		},
		"secrets": {
			"allowed_names": ["calendar_*"]
		},
		"channel": {
			"allowed_paths": ["/webhook/calendar"],
			"allow_polling": true,
			"min_poll_interval_ms": 60000,
			"workspace_prefix": "channels/calendar/",
			"emit_rate_limit": {
				"messages_per_minute": 30,
				"messages_per_hour": 500
			}
		}
	},
	"config": {
		"caldav_url": "http://localhost:8080",
		"calendar_name": "default",
		"poll_interval_ms": 60000
	}
}
