# Root justfile — delegates to sub-project build systems.
#
# mojo-gui is a multi-renderer reactive GUI framework. This root justfile
# provides convenience aliases for common operations across all renderers.
#
# Sub-project justfiles:
#   - web/justfile    — WASM build, JS tests, browser serving
#   - desktop/        — Blitz shim build (via cargo), native Mojo build
#
# Shared examples (examples/) compile identically for both targets:
#
#   # Web (WASM):
#   mojo build examples/counter/main.mojo --target wasm64-wasi -I core/src -I web/src -I examples
#
#   # Desktop (native, Wayland-only):
#   mojo build examples/counter/main.mojo -I core/src -I desktop/src -I examples

# Default: build the web target
default: build

# ── Runtime library path (Nix) ───────────────────────────────────────────────
#
# The Blitz renderer (via Winit) uses dlopen to load Wayland and GPU libraries
# at runtime. In a Nix environment these live in /nix/store paths that aren't
# on the default ld search path. We use nix eval to resolve the paths and
# patchelf to bake them into libmojo_blitz.so during build-shim.
#
# The same paths are also used as LD_LIBRARY_PATH fallback for run-desktop.

_blitz-rpath := `nix eval --raw --impure --expr 'let pkgs = import <nixpkgs> {}; in pkgs.lib.makeLibraryPath (with pkgs; [ wayland libxkbcommon vulkan-loader libGL fontconfig freetype ])' 2>/dev/null || echo ""`

# ── Web target ───────────────────────────────────────────────────────────────

# Build the WASM binary (delegates to web/justfile)
build:
    cd web && just build

# Incremental build — skip if out.wasm is newer than all source files
build-if-changed:
    cd web && just build-if-changed

# Precompile WASM for faster loading
precompile:
    cd web && just precompile

# Build Mojo test binaries (parallel, incremental)
test-build *FILTER:
    cd web && just test-build {{ FILTER }}

# Run precompiled Mojo test binaries
test-run *FILTER:
    cd web && just test-run {{ FILTER }}

# Build + run Mojo test binaries
test *FILTER:
    cd web && just test {{ FILTER }}

# Run JS integration tests
test-js:
    cd web && just test-js

# Run all tests (Mojo + JS)
test-all:
    cd web && just test-all

# End-to-end browser tests via headless Servo + WebDriver
test-browser:
    cd web && just test-browser

# Browser tests with verbose Servo output
test-browser-verbose:
    cd web && just test-browser-verbose

# Single app browser test
test-browser-app app:
    cd web && just test-browser-app {{ app }}

# Serve examples in browser
serve: build
    @echo "Open http://localhost:4507/web/examples/counter/"
    @echo "Open http://localhost:4507/web/examples/todo/"
    @echo "Open http://localhost:4507/web/examples/bench/"
    @echo "Open http://localhost:4507/web/examples/app/"
    deno run --allow-net --allow-read jsr:@std/http/file-server

# ── Desktop target (Wayland-only) ───────────────────────────────────────────

# Build the Blitz C shim (Rust cdylib) and patchelf runtime rpaths
build-shim:
    cd desktop/shim && cargo build --release --lib
    @# Bake Wayland/GPU library rpaths into the cdylib so dlopen finds them
    @if [ -n "{{ _blitz-rpath }}" ] && command -v patchelf >/dev/null 2>&1; then \
        patchelf --set-rpath "{{ _blitz-rpath }}" desktop/shim/target/release/libmojo_blitz.so && \
        echo "patchelf: set rpath on libmojo_blitz.so"; \
    fi

# Build a shared example for desktop (native binary)
# Usage: just build-desktop counter
build-desktop app:
    mkdir -p build
    mojo build examples/{{ app }}/main.mojo \
        -I core/src -I desktop/src -I examples \
        -o build/{{ app }}-desktop

# Build all shared examples for desktop
build-desktop-all: (build-desktop "counter") (build-desktop "todo") (build-desktop "bench") (build-desktop "app")

# Run a shared example on desktop (Wayland)
# Usage: just run-desktop counter
run-desktop app: (build-desktop app)
    LD_LIBRARY_PATH="{{ _blitz-rpath }}:${LD_LIBRARY_PATH:-}" \
    MOJO_BLITZ_LIB="{{ justfile_directory() }}/desktop/shim/target/release" \
    ./build/{{ app }}-desktop

# Run all shared examples on desktop (sequentially — each opens a window)
run-desktop-all: build-desktop-all
    @echo "Running counter…"
    just run-desktop counter
    @echo "Running todo…"
    just run-desktop todo
    @echo "Running bench…"
    just run-desktop bench
    @echo "Running app…"
    just run-desktop app

# ── Desktop tests (Rust integration tests for the Blitz shim) ───────────

# Run Blitz shim integration tests (headless — no display needed)
test-desktop:
    cd desktop/shim && cargo test

# ── Cross-target builds ──────────────────────────────────────────────────

# Build a shared example for web (WASM)
# Usage: just build-web counter
build-web app:
    mkdir -p build
    mojo build examples/{{ app }}/main.mojo \
        --target wasm64-wasi \
        -I core/src -I web/src -I examples \
        -o build/{{ app }}-web.wasm

# Build all shared examples for both targets
build-all: build build-desktop-all

# Run all tests (Mojo + JS + desktop)
test-all-targets: test-all test-desktop

# ── Cleanup ──────────────────────────────────────────────────────────────────

# Remove build artifacts
clean:
    rm -rf build/
    rm -rf web/build/
    cd desktop/shim && cargo clean 2>/dev/null || true
